$successCount = 0
$failCount = 0
$failures = @()
$unexpected = @()

function Add-ClassicLinksInclude {
    param(
        [string]$FilePath,
        [string]$RelPath
    )
    
    $fullPath = Join-Path $base $FilePath
    if (-not (Test-Path $fullPath)) {
        return @{ Success = $false; Reason = "File not found" }
    }
    
    $content = Get-Content $fullPath -Raw
    $lines = Get-Content $fullPath
    
    if ($content -match '\[!INCLUDE \[classic-links\]') {
        return @{ Success = $false; Reason = "Already has classic-links include" }
    }
    
    $bannerIdx = -1
    for ($i = 0; $i -lt $lines.Count; $i++) {
        if ($lines[$i] -match '^\*\*Currently viewing:\*\*') {
            $bannerIdx = $i
            break
        }
    }
    
    $insertAfterIdx = -1
    $insertMethod = ""
    
    if ($bannerIdx -ge 0) {
        $insertAfterIdx = $bannerIdx
        $insertMethod = "after-banner"
    } else {
        for ($i = 0; $i -lt $lines.Count; $i++) {
            if ($lines[$i] -match '^# ') {
                $insertAfterIdx = $i
                $insertMethod = "after-h1"
                break
            }
        }
    }
    
    if ($insertAfterIdx -lt 0) {
        return @{ Success = $false; Reason = "No banner or H1 found" }
    }
    
    $includeLine = "[!INCLUDE [classic-links]($RelPath)]"
    
    $newLines = [System.Collections.ArrayList]::new()
    for ($i = 0; $i -le $insertAfterIdx; $i++) {
        [void]$newLines.Add($lines[$i])
    }
    
    [void]$newLines.Add("")
    [void]$newLines.Add($includeLine)
    [void]$newLines.Add("")
    
    $nextIdx = $insertAfterIdx + 1
    if ($nextIdx -lt $lines.Count -and $lines[$nextIdx].Trim() -eq "") {
        $nextIdx++
    }
    
    for ($i = $nextIdx; $i -lt $lines.Count; $i++) {
        [void]$newLines.Add($lines[$i])
    }
    
    $newLines | Set-Content $fullPath -Encoding utf8NoBOM
    return @{ Success = $true; Method = $insertMethod }
}

foreach ($f in $depth1) {
    $result = Add-ClassicLinksInclude -FilePath $f -RelPath "includes/classic-links.md"
    if ($result.Success) { $successCount++ } else { $failCount++; $failures += "$f : $($result.Reason)" }
    if ($result.Method -eq "after-h1") { $unexpected += "$f : no banner, used H1 fallback" }
}

foreach ($f in $depth2) {
    $result = Add-ClassicLinksInclude -FilePath $f -RelPath "../includes/classic-links.md"
    if ($result.Success) { $successCount++ } else { $failCount++; $failures += "$f : $($result.Reason)" }
    if ($result.Method -eq "after-h1") { $unexpected += "$f : no banner, used H1 fallback" }
}

foreach ($f in $depth3) {
    $result = Add-ClassicLinksInclude -FilePath $f -RelPath "../../includes/classic-links.md"
    if ($result.Success) { $successCount++ } else { $failCount++; $failures += "$f : $($result.Reason)" }
    if ($result.Method -eq "after-h1") { $unexpected += "$f : no banner, used H1 fallback" }
}

Write-Host "=== RESULTS ==="
Write-Host "Successfully edited: $successCount files"
Write-Host "Failed/Skipped: $failCount files"

if ($failures.Count -gt 0) {
    Write-Host "`n=== FAILURES ==="
    $failures | ForEach-Object { Write-Host "  $_" }
}

if ($unexpected.Count -gt 0) {
    Write-Host "`n=== UNEXPECTED STRUCTURE ==="
    $unexpected | ForEach-Object { Write-Host "  $_" }
}

Write-Host "`nTotal files processed: $($successCount + $failCount)"
